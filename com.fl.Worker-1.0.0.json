{
  "RecipeFormatVersion": "2020-01-25",
  "ComponentName": "com.fl.Worker",
  "ComponentVersion": "1.0.0",
  "ComponentConfiguration": {
    "DefaultConfiguration": {
      "AsuId": "1224208336",
      "WorkerId": "9",
      "accessControl": {
        "aws.greengrass.ipc.mqttproxy": {
          "com.fl.Worker:mqttproxy:1": {
            "policyDescription": "Subscribe and Publish to FL round trigger topic",
            "operations": [
              "aws.greengrass#SubscribeToIoTCore",
              "aws.greengrass#PublishToIoTCore"
            ],
            "resources": [
              "fl/1224208336/next-round"
            ]
          }
        }
      }
    }
  },
  "Manifests": [
    {
      "Platform": {
        "os": "linux"
      },
      "Lifecycle": {
        "run": "PYTHONPATH=/home/ubuntu/.local/lib/python3.10/site-packages python3 -u {artifacts:path}/worker.py {configuration:/AsuId} {configuration:/WorkerId}"
      },
      "Artifacts": [
        {
          "URI": "greengrass:worker.py"
        }
      ]
    }
  ]
}